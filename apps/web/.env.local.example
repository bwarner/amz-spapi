# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=  # openssl rand -hex 32
AUTH0_AUDIENCE=
APP_BASE_URL=https://local.sellavant.com:9443

# AI Provider: anthropic | bedrock | openai
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AWS_BEDROCK_ROLE_ARN=arn:aws:iam::...  # for Vercel OIDC to Bedrock
# AWS_BEDROCK_REGION=us-east-1
# AWS_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# AWS_BEDROCK_FAST_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# AWS_BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Amazon SP-API LWA App (for OAuth connect + direct API access)
LWA_CLIENT_ID=amzn1.application-oa2-client.xxx
LWA_CLIENT_SECRET=
LWA_REFRESH_TOKEN=Atzr|xxx  # Optional: env var fallback when Couchbase credentials not available
SP_MARKETPLACE_ID=ATVPDKIKX0DER

# Amazon Ads API LWA App (separate app from SP-API)
ADS_CLIENT_ID=amzn1.application-oa2-client.yyy
ADS_CLIENT_SECRET=

# Amazon OAuth callback (shared by SP-API and Ads API)
AMAZON_OAUTH_REDIRECT_URI=https://local.sellavant.com:9443/api/amazon/callback

# Couchbase Data API (Vercel integration-compatible names)
CB_DATA_API_URL=https://<your-data-api-endpoint>
CB_USERNAME=
CB_PASSWORD=
CB_BUCKET=sellavant
CB_SCOPE=SellAvantDev

# Shared media asset storage (image bytes in S3, metadata in Couchbase)
AWS_REGION=us-east-1
AWS_PROFILE=sellavant-dev
MEDIA_ASSETS_BUCKET=sellavant-media-assets-dev-853583158600-us-east-1

# Optional source extraction fallback for pages that block direct fetch
# Actor ID may be apify~website-content-crawler or a marketplace scraper actor.
APIFY_TOKEN=
APIFY_SOURCE_ACTOR_ID=apify~website-content-crawler

# A+ image generation. Uses the AI Gateway (AI_GATEWAY_API_KEY) with a dedicated
# image model. Default backend is OpenAI gpt-image-1; the active backend can be
# A/B-switched per user via the PostHog flag `aplus-image-model` (see below), or
# forced with A_PLUS_IMAGE_VARIANT (dev override, below).
A_PLUS_IMAGE_QUALITY=medium
# Override model slugs per variant (optional — sensible gateway defaults built in):
# A_PLUS_IMAGE_MODEL_OPENAI=openai/gpt-image-1
# A_PLUS_IMAGE_MODEL_GOOGLE=google/imagen-4.0-generate-001
# A_PLUS_IMAGE_MODEL_GROK=xai/grok-imagine-image

# Dev/local A/B overrides — set either of these to force a variant WITHOUT
# PostHog (takes precedence over the flag). Leave unset to use PostHog / defaults.
# A_PLUS_IMAGE_VARIANT=openai          # openai | google | grok  (also the no-flag default)
# A_PLUS_GENERATION_MODE=single        # single | parallel

# PostHog — server reads these multivariate flags:
#   • `aplus-image-model`     (openai | google | grok)  → image backend
#   • `aplus-generation-mode` (single | parallel)       → 1 LLM call vs 1 per module
# Client analytics use the NEXT_PUBLIC_* keys. All optional: with no key set,
# image gen defaults to openai and generation defaults to single-call.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
