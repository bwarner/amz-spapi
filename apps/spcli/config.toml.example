# SP-API Configuration Example
# Copy this file to config.toml and fill in your credentials

[sp_api]
# LWA (Login with Amazon) credentials from Amazon Seller Central
# Get these from: https://sellercentral.amazon.com/apps/authorize/consent
client_id = "amzn1.application-oa2-client.YOUR_CLIENT_ID"
client_secret = "amzn1.oa2-cs.v1.YOUR_CLIENT_SECRET"

# Amazon marketplace ID
# US: ATVPDKIKX0DER, CA: A2EUQ1WTGCTBG2, UK: A1F83G8C2ARO7P
marketplace_id = "ATVPDKIKX0DER"

# Region: NA (North America), EU (Europe), FE (Far East)
region = "NA"

# Optional: Profile name (defaults to "default")
profile_name = "default"

# Optional: Seller/Merchant ID
seller_id = "YOUR_SELLER_ID"
