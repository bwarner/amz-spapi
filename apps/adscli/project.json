{
  "name": "adscli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/adscli/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "bundle": true,
        "thirdParty": false,
        "generatePackageJson": true,
        "format": [
          "esm"
        ],
        "main": "apps/adscli/src/main.ts",
        "outputPath": "dist/apps/adscli",
        "tsConfig": "apps/adscli/tsconfig.app.json",
        "assets": [
          "apps/adscli/src/assets"
        ],
        "esbuildOptions": {
          "banner": {
            "js": "#!/usr/bin/env node"
          },
          "sourcemap": true
        }
      },
      "configurations": {
        "development": {
          "esbuildOptions": {
            "sourcemap": true
          }
        },
        "production": {
          "esbuildOptions": {
            "sourcemap": false
          }
        }
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build"
      ],
      "options": {
        "command": "node dist/apps/adscli/main.js"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/adscli/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "apps/adscli/**/*.{ts,tsx,js,jsx}"
        ]
      }
    }
  }
}
