{
  "name": "adscli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/adscli/src",
  "projectType": "application",
  "tags": [],

  "targets": {
        "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "bundle": true,
        "external": ["pino", "pino-pretty"],                          
        "format": ["cjs"],                        
        "main": "apps/adscli/src/main.ts",
        "outputPath": "dist/apps/adscli",
        "outfile": "adscli.js",                  
        "tsConfig": "apps/adscli/tsconfig.app.json",
        "assets": ["apps/adscli/src/assets"],


        "esbuildOptions": {
          "banner": {
            "js": "#!/usr/bin/env node"
          },
          "sourcemap": true
        }
      },

      "configurations": {
        "development": {
          "esbuildOptions": { "sourcemap": true }
        },
        "production": {
          "esbuildOptions": { "sourcemap": false }
        }
      }
    },
    "run": {
      "executor": "@nx/js:node",
      "dependsOn": ["build"],
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "adscli:build",
        "watch": false,  
        "args": []
      },
      "configurations": {
        "development": {
          "buildTarget": "adscli:build:development"
        },
        "production": {
          "buildTarget": "adscli:build:production"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/adscli/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/adscli/**/*.{ts,tsx,js,jsx}"]
      }
    }
  }
}
