{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "emitDecoratorMetadata": false,
    "esModuleInterop": true,
    "experimentalDecorators": false,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "incremental": true,
    "isolatedModules": true,
    "lib": ["es2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "pretty": true,
    "removeComments": false,
    "resolveJsonModule": true,
    "skipDefaultLibCheck": false,
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": true,
    "target": "ES2024",
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["apps/web/src/components/*"],
      "@/lib/*": ["apps/web/src/lib/*"],
      "@/hooks/*": ["apps/web/src/hooks/*"],
      "@farvisionllc/ad-client": ["packages/ad-client/src/index.ts"],
      "@farvisionllc/ad-models": ["packages/ad-models/src/index.ts"],
      "@farvisionllc/amazon-ads-generated": [
        "dist/packages/amazon-ads-generated/src/index.js"
      ],
      "@farvisionllc/amazon-ads-generated/*": [
        "dist/packages/amazon-ads-generated/src/lib/*"
      ],
      "@farvisionllc/amazon-ads-schema": [
        "packages/amazon-ads-schema/src/index.ts"
      ],
      "@farvisionllc/api-services": ["packages/api-services/src/index.ts"],
      "@farvisionllc/models": ["packages/models/src/index.ts"]
    }
  }
}
