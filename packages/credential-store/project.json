{
  "name": "credential-store",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/credential-store/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/packages/credential-store",
        "main": "packages/credential-store/src/index.ts",
        "tsConfig": "packages/credential-store/tsconfig.lib.json",
        "assets": [
          "packages/credential-store/*.md",
          "packages/credential-store/package.json"
        ],
        "updateBuildableProjectDepsInPackageJson": true
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "packages/credential-store/jest.config.ts"
      }
    }
  }
}
